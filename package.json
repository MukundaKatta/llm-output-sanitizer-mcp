{
  "name": "@mukundakatta/llm-output-sanitizer-mcp",
  "version": "0.1.0",
  "mcpName": "io.github.MukundaKatta/llm-output-sanitizer",
  "description": "MCP server exposing llm-output-sanitizer: strip dangerous HTML, SQL, and shell snippets from LLM output before rendering, executing, or persisting. Built for Claude Desktop, Cursor, Cline, Windsurf, and Zed.",
  "type": "module",
  "bin": {
    "mcp-llm-output-sanitizer": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "cline",
    "windsurf",
    "zed",
    "sanitize",
    "xss",
    "sql-injection",
    "shell-injection",
    "llm",
    "agent-safety"
  ],
  "author": "Mukunda Katta <mukunda.vjcs6@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/MukundaKatta/llm-output-sanitizer-mcp#readme",
  "bugs": {
    "url": "https://github.com/MukundaKatta/llm-output-sanitizer-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MukundaKatta/llm-output-sanitizer-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mukundakatta/llm-output-sanitizer": "^0.1.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^26.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
